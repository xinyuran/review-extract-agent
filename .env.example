# ============================================================
# Extract Agent 环境配置文件
# ============================================================
# 使用方法：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 修改下方的配置值
#   3. 启动 Agent 时会自动加载 .env
#
# 配置优先级：.env 文件 > YAML 配置文件 > 代码默认值
# ============================================================

# ==================== 后端模式 ====================
# auto        - 根据 base_url 自动判断（默认）
#      - 使用云服务商 API（OpenAI / DeepSeek / 通义千问等）
# local_model - 使用本地部署模型（vLLM / Ollama 等）
# offline     - 不使用任何 LLM，仅 jieba 提取关键词，无情感分析
BACKEND_MODE=offline

# ==================== Agent LLM 配置 ====================
# Agent LLM 负责规划、推理、工具调度
AGENT_LLM_BASE_URL=http://localhost:8001/v1
AGENT_LLM_API_KEY=dummy
AGENT_LLM_MODEL=Qwen2.5-7B-Instruct
AGENT_LLM_TEMPERATURE=0
AGENT_LLM_MAX_TOKENS=4096

# ==================== Tool LLM 配置 ====================
# Tool LLM 用于关键词提取、情感分析等工具内部调用
# 若不设置则默认与 Agent LLM 相同
TOOL_LLM_BASE_URL=http://localhost:8002/v1
TOOL_LLM_API_KEY=dummy
TOOL_LLM_MODEL=finetuned-model
TOOL_LLM_TEMPERATURE=0
TOOL_LLM_MAX_TOKENS=4096

# ==================== Tool LLM 推理参数 ====================
TOOL_LLM_SEED=42
TOOL_LLM_FREQUENCY_PENALTY=0.3
TOOL_LLM_REPETITION_PENALTY=1.1

# ==================== Agent 控制参数 ====================
# 工具调用模式: native / prompt / auto
AGENT_TOOL_CALLING_MODE=native
AGENT_MAX_STEPS=10
AGENT_TIMEOUT=1200
TOOL_TIMEOUT=1200

# ==================== 反思器配置 ====================
ENABLE_REFLECTION=true
REFLECTION_MAX_ROUNDS=5
REFLECTION_SCORE_THRESHOLD=0.7

# ==================== Skill 层配置 ====================
# 自定义 skills 目录（默认使用 extract_agent/skills/）
# SKILLS_DIR=

# ==================== 轨迹采集配置 ====================
# 是否启用轨迹记录（用于生成 SFT 训练数据）
ENABLE_TRAJECTORY=false
# 轨迹文件输出目录
TRAJECTORY_OUTPUT_DIR=extract_agent_output/trajectory
# 是否在轨迹中包含 Tool LLM 的 thinking 文本
TRAJECTORY_INCLUDE_THINKING=true

# ==================== 知识积累配置 ====================
# 是否启用知识积累（评论者画像 + 商品画像自动追踪）
ENABLE_KNOWLEDGE=false
# 知识存储目录（评论者画像 + 商品画像）
KNOWLEDGE_STORE_DIR=extract_agent_output/knowledge_store

# ==================== Redis 配置 ====================
# Redis 连接地址（用于异步任务和结果缓存）
# REDIS_URL=redis://127.0.0.1:6379/0
# Redis 密码（也可以在 REDIS_URL 中以 redis://:password@host:port/db 格式指定）
# REDIS_PASSWORD=

# ==================== API 安全配置 ====================
# CORS 允许的域名（逗号分隔，默认仅 localhost:3000）
CORS_ALLOWED_ORIGINS=http://localhost:3000
# API Key 认证（未设置则不启用认证，开发模式友好）
# API_KEY=your-secret-api-key

# ==================== 调试 ====================
DEBUG=false

# ============================================================
# 云服务 API 配置示例
# ============================================================
#
# --- OpenAI ---
# AGENT_LLM_BASE_URL=https://api.openai.com/v1
# AGENT_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# AGENT_LLM_MODEL=gpt-4o-mini
# TOOL_LLM_BASE_URL=https://api.openai.com/v1
# TOOL_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# TOOL_LLM_MODEL=gpt-4o-mini
#
# --- DeepSeek ---
# AGENT_LLM_BASE_URL=https://api.deepseek.com/v1
# AGENT_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# AGENT_LLM_MODEL=deepseek-chat
# TOOL_LLM_BASE_URL=https://api.deepseek.com/v1
# TOOL_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# TOOL_LLM_MODEL=deepseek-chat
#
# --- 通义千问 ---
# AGENT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AGENT_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# AGENT_LLM_MODEL=qwen-plus
#
# --- 离线模式（不需要 LLM）---
# BACKEND_MODE=offline
# ============================================================
